# Copy to .env for local runs:  cp .env.example .env  then fill in your key.

ENVIRONMENT=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://fleet:fleet@localhost:5432/fleet

# --- LLM provider: openai (default) | anthropic | bedrock | ollama ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

# REQUIRED for OpenAI. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-replace-me

# --- Embeddings (Phase 2 RAG) ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Other providers (only if you switch LLM_PROVIDER) ---
# ANTHROPIC_API_KEY=sk-ant-...
# AWS_REGION=eu-central-1
# OLLAMA_BASE_URL=http://localhost:11434
